{
    "compilerOptions": {
        "outDir": "dist",
        "rootDir": "src",
        "moduleResolution": "nodenext",
        "module": "nodenext",
        "allowJs": true,
        "strictNullChecks": true,
        "alwaysStrict": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true
    },
    "include": [ "src" ]
}