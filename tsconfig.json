{
    "compilerOptions": {
        "outDir": "dist",
        "allowJs": true,
        "strictNullChecks": true,
        "alwaysStrict": true,
        "esModuleInterop": true,
        "noImplicitAny": true,
        "noImplicitReturns": true,
        "noImplicitOverride": true
    },
    "include": [ "src" ]
}